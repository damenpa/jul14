<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <defs>
    <radialGradient id="disco-grad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#f4e4a1;stop-opacity:0.9"/>
      <stop offset="40%" style="stop-color:#d4af37;stop-opacity:0.8"/>
      <stop offset="100%" style="stop-color:#b87333;stop-opacity:0.6"/>
    </radialGradient>
  </defs>
  <circle cx="200" cy="200" r="190" fill="url(#disco-grad)"/>
  <!-- Surcos concéntricos -->
  <circle cx="200" cy="200" r="180" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="170" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="160" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="150" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="140" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="130" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="120" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="110" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="100" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="90" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="80" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="70" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="60" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <circle cx="200" cy="200" r="50" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="200" r="40" fill="none" stroke="#b87333" stroke-width="0.5" opacity="0.4"/>
  <!-- Centro -->
  <circle cx="200" cy="200" r="30" fill="#05050a" stroke="#d4af37" stroke-width="2"/>
  <text x="200" y="205" font-family="monospace" font-size="10" fill="#d4af37" text-anchor="middle">VOYAGER</text>
