<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="foto-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#d4af37;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#b87333;stop-opacity:0.2"/>
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="#1a1a2e"/>
  <rect x="10" y="10" width="580" height="380" fill="url(#foto-grad)" rx="4"/>
  <!-- Marco dorado -->
  <rect x="10" y="10" width="580" height="380" fill="none" stroke="#d4af37" stroke-width="2" rx="4"/>
  <!-- Icono de foto -->
  <circle cx="300" cy="180" r="40" fill="none" stroke="#d4af37" stroke-width="1.5" opacity="0.5"/>
  <polygon points="300,140 340,200 260,200" fill="none" stroke="#d4af37" stroke-width="1.5" opacity="0.5"/>
  <circle cx="320" cy="170" r="8" fill="#d4af37" opacity="0.4"/>
  <!-- Texto -->
  <text x="300" y="260" font-family="serif" font-size="16" fill="#d4af37" text-anchor="middle" opacity="0.6">Foto de Recuerdo</text>
  <text x="300" y="285" font-family="monospace" font-size="10" fill="#b87333" text-anchor="middle" opacity="0.5">placeholder — reemplazar con imagen real</text>
</svg>
